# Production Environment Configuration
# Auth Service - Production

# MongoDB Atlas Connection (REQUIRED for production)
# Format: mongodb+srv://username:password@cluster.mongodb.net/database?options
MONGODB_URI=mongodb+srv://${MONGO_USER}:${MONGO_PASSWORD}@${MONGO_CLUSTER}/lunchbox_db?retryWrites=true&w=majority

# Server Configuration
PORT=3003
NODE_ENV=production

# Database fallback (MUST be disabled for production)
ENABLE_INMEMORY_FALLBACK=0

# OTP Configuration (disable debug mode in production)
OTP_DEBUG_MODE=0
REQUIRE_CUSTOMER_REGISTRATION_OTP=1

# Email OTP - SendGrid (recommended for production)
SENDGRID_API_KEY=${SENDGRID_API_KEY}
SENDGRID_FROM_EMAIL=noreply@ekartapp.com

# Email OTP - Gmail (optional, requires app password)
# GMAIL_USER=your-email@gmail.com
# GMAIL_APP_PASSWORD=your-app-password

# SMS OTP - Twilio (optional)
# TWILIO_ACCOUNT_SID=your-account-sid
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_FROM_NUMBER=+1234567890

# External APIs
GOOGLE_MAPS_API_KEY=${GOOGLE_MAPS_API_KEY}
OPENWEATHER_API_KEY=${OPENWEATHER_API_KEY}

# CORS Configuration
CORS_ALLOWED_ORIGINS=https://ekart.com,https://www.ekart.com,https://app.ekart.com

# Feature Flags
FEATURE_VOICE_BOOKING=1
FEATURE_LIVE_TRACKING=1
FEATURE_CHAT_SUPPORT=1
