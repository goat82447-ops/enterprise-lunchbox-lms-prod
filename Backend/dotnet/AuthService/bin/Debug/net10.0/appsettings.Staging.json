{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "mongodb+srv://${MONGO_USER}:${MONGO_PASSWORD}@${MONGO_CLUSTER}/lunchbox_db_staging?retryWrites=true&w=majority"
  },
  "Database": {
    "Provider": "MongoDB",
    "ConnectionString": "${MONGO_CONNECTION_STRING}",
    "EnableFallback": true
  },
  "Cors": {
    "AllowedOrigins": "${CORS_ALLOWED_ORIGINS}"
  },
  "Api": {
    "BaseUrl": "${API_BASE_URL}",
    "Port": "${API_PORT:5000}"
  }
}
