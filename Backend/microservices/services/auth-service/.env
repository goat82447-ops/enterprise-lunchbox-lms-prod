# MongoDB Atlas Connection
# Account: Akhil @ cluster0
MONGODB_URI=mongodb+srv://Akhil:Welcome2@cluster0.yosm6gj.mongodb.net/lunchbox_db

# Local MongoDB (uncomment to use local instead of Atlas)
# MONGODB_URI=mongodb://localhost:27017/lunchbox_db

# Server Port
PORT=3003

# OTP Debug Mode (set to 1 to print OTP in console)
OTP_DEBUG_MODE=0

# Set to 1 to force OTP verification after customer registration
REQUIRE_CUSTOMER_REGISTRATION_OTP=1

# Set to 0 to force Atlas-only mode (disable in-memory fallback)
ENABLE_INMEMORY_FALLBACK=1

# Optional: Email OTP (Gmail)
# GMAIL_USER=your-email@gmail.com
# GMAIL_APP_PASSWORD=your-app-password

# Optional: Email OTP (SendGrid)
# SENDGRID_API_KEY=your-sendgrid-api-key
# SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# Optional: SMS OTP (Twilio)
# TWILIO_ACCOUNT_SID=your-account-sid
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_FROM_NUMBER=+1234567890

# Optional: Google Maps API
# GOOGLE_MAPS_API_KEY=your-google-maps-key

# Optional: OpenWeather API
# OPENWEATHER_API_KEY=your-openweather-key
