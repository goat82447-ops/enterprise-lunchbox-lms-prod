app.post('/api/auth/voice-verify', requireSession, async (req, res) => {
  const { spokenText } = req.body || {};
  const challenge = await VoiceChallenge.findOne({ session_token: req.session.token, consumed: 0, expires_at: { $gt: nowIso() } }).sort({ created_at: -1 }).lean();
  if (!challenge) return res.status(400).json({ error: 'No active voice challenge.' });
  const expected = normalize(challenge.phrase);
  const spoken = normalize(spokenText || '');
  if (expected !== spoken) return res.status(400).json({ error: 'Voice phrase does not match challenge.' });
  await VoiceChallenge.updateOne({ _id: challenge._id }, { $set: { consumed: 1 } });
  await AuthSession.updateOne({ token: req.session.token }, { $set: { voice_verified: 1 } });
  return res.json({ message: 'Voice step-up successful.' });
});

